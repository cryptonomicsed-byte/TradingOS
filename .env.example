# TradingOS Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════
# ANTHROPIC / CLAUDE
# ═══════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=8192
AGENT_TEMPERATURE=0.3

# ═══════════════════════════════════════════════
# MARKET DATA
# ═══════════════════════════════════════════════
COINGECKO_API_KEY=
BIRDEYE_API_KEY=
DEXSCREENER_API_KEY=
SOLSCAN_API_KEY=
HELIUS_API_KEY=
ETHERSCAN_API_KEY=

# ═══════════════════════════════════════════════
# DEX / EXECUTION
# ═══════════════════════════════════════════════
JUPITER_API_URL=https://quote-api.jup.ag/v6
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/...

# ═══════════════════════════════════════════════
# SOCIAL INTELLIGENCE
# ═══════════════════════════════════════════════
TWITTER_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ═══════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════
DATABASE_URL=postgresql://tradingos:tradingos@postgres:5432/tradingos
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

# ═══════════════════════════════════════════════
# SERVICE PORTS
# ═══════════════════════════════════════════════
SIGNAL_BUS_PORT=7700
AGENT_RUNTIME_PORT=7701
API_GATEWAY_PORT=8080
MCP_SERVER_PORT=4000
DASHBOARD_PORT=3000
QUANT_ENGINE_PORT=7702

# ═══════════════════════════════════════════════
# PARLIAMENT CONFIGURATION
# ═══════════════════════════════════════════════
PARLIAMENT_QUORUM=0.67          # 67% of agents must vote
PARLIAMENT_MIN_VOTES=3          # Minimum agent votes required
PARLIAMENT_TIMEOUT_SECS=30      # Max seconds for deliberation
CONVICTION_THRESHOLD=0.75       # Min score for execution
CHALLENGER_ENABLED=true         # Enable devil's advocate agents
MEMORY_COURT_LOOKBACK_DAYS=90   # Historical pattern search window

# ═══════════════════════════════════════════════
# RISK MANAGEMENT
# ═══════════════════════════════════════════════
MAX_POSITION_PCT=0.05           # Max 5% of portfolio per trade
HARD_STOP_LOSS_PCT=0.15         # -15% hard stop
TRAILING_TP_ACTIVATION_PCT=0.05 # +5% activates trailing
TRAILING_TP_TRAIL_PCT=0.05      # Trail 5% from peak
MAX_HOLD_HOURS=72               # Max position hold time
MEV_PROTECTION_ENABLED=true

# ═══════════════════════════════════════════════
# AGENT EVOLUTION
# ═══════════════════════════════════════════════
AGENT_REPUTATION_DECAY=0.95     # Reputation decay per day
AGENT_MIN_REPUTATION=0.1        # Below this: retrain
AGENT_EVOLUTION_INTERVAL=86400  # Evolve agents every 24h
STRATEGY_FITNESS_WINDOW=30      # Days for fitness evaluation

# ═══════════════════════════════════════════════
# WASM PLUGIN SYSTEM
# ═══════════════════════════════════════════════
PLUGIN_DIR=/app/plugins/strategies
PLUGIN_HOT_RELOAD=true
PLUGIN_SANDBOX_MEMORY_MB=64
PLUGIN_SANDBOX_TIMEOUT_MS=100

# ═══════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════
OTEL_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=info
METRICS_ENABLED=true
TRACING_ENABLED=true
