# TradingOS Environment Configuration
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════
# LLM PROVIDER — plug in any provider you have
# ═══════════════════════════════════════════════
# Primary selector (agents inherit this unless overridden per-agent)
LLM_PROVIDER=anthropic          # anthropic | openai | groq | ollama | google | openai-compat
LLM_MODEL=                      # Leave empty to use provider default
LLM_API_KEY=                    # Overrides the per-provider key below if set
LLM_BASE_URL=                   # Required for openai-compat / custom endpoints

AGENT_TEMPERATURE=0.3
AGENT_MAX_TOKENS=4096

# ── Provider API keys (set the one matching LLM_PROVIDER) ──
ANTHROPIC_API_KEY=sk-ant-...    # Anthropic Claude
OPENAI_API_KEY=sk-...           # OpenAI GPT-4o / o1
GROQ_API_KEY=gsk_...            # Groq (ultra-fast Llama / Mixtral)
GOOGLE_API_KEY=AIza...          # Google Gemini

# ── Example configs (copy the block you want) ──
# Anthropic Claude:    LLM_PROVIDER=anthropic   LLM_MODEL=claude-sonnet-4-6
# OpenAI GPT-4o:       LLM_PROVIDER=openai      LLM_MODEL=gpt-4o
# Groq Llama-3.3-70B:  LLM_PROVIDER=groq        LLM_MODEL=llama-3.3-70b-versatile
# Local Ollama:        LLM_PROVIDER=ollama      LLM_MODEL=llama3.2
# Google Gemini Flash: LLM_PROVIDER=google      LLM_MODEL=gemini-2.0-flash
# Together AI:         LLM_PROVIDER=together    LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
# Custom endpoint:     LLM_PROVIDER=openai-compat  LLM_BASE_URL=https://... LLM_API_KEY=...

# ═══════════════════════════════════════════════
# MARKET DATA
# ═══════════════════════════════════════════════
COINGECKO_API_KEY=
BIRDEYE_API_KEY=
DEXSCREENER_API_KEY=
SOLSCAN_API_KEY=
HELIUS_API_KEY=
ETHERSCAN_API_KEY=

# ═══════════════════════════════════════════════
# DEX / EXECUTION
# ═══════════════════════════════════════════════
JUPITER_API_URL=https://quote-api.jup.ag/v6
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/...

# ═══════════════════════════════════════════════
# SOCIAL INTELLIGENCE
# ═══════════════════════════════════════════════
TWITTER_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ═══════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════
DATABASE_URL=postgresql://tradingos:tradingos@postgres:5432/tradingos
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

# ═══════════════════════════════════════════════
# SERVICE PORTS
# ═══════════════════════════════════════════════
SIGNAL_BUS_PORT=7700
AGENT_RUNTIME_PORT=7701
API_GATEWAY_PORT=8080
MCP_SERVER_PORT=4000
DASHBOARD_PORT=3000
QUANT_ENGINE_PORT=7702

# ═══════════════════════════════════════════════
# PARLIAMENT CONFIGURATION
# ═══════════════════════════════════════════════
PARLIAMENT_QUORUM=0.67          # 67% of agents must vote
PARLIAMENT_MIN_VOTES=3          # Minimum agent votes required
PARLIAMENT_TIMEOUT_SECS=30      # Max seconds for deliberation
CONVICTION_THRESHOLD=0.75       # Min score for execution
CHALLENGER_ENABLED=true         # Enable devil's advocate agents
MEMORY_COURT_LOOKBACK_DAYS=90   # Historical pattern search window

# ═══════════════════════════════════════════════
# RISK MANAGEMENT
# ═══════════════════════════════════════════════
MAX_POSITION_PCT=0.05           # Max 5% of portfolio per trade
HARD_STOP_LOSS_PCT=0.15         # -15% hard stop
TRAILING_TP_ACTIVATION_PCT=0.05 # +5% activates trailing
TRAILING_TP_TRAIL_PCT=0.05      # Trail 5% from peak
MAX_HOLD_HOURS=72               # Max position hold time
MEV_PROTECTION_ENABLED=true

# ═══════════════════════════════════════════════
# AGENT EVOLUTION
# ═══════════════════════════════════════════════
AGENT_REPUTATION_DECAY=0.95     # Reputation decay per day
AGENT_MIN_REPUTATION=0.1        # Below this: retrain
AGENT_EVOLUTION_INTERVAL=86400  # Evolve agents every 24h
STRATEGY_FITNESS_WINDOW=30      # Days for fitness evaluation

# ═══════════════════════════════════════════════
# WASM PLUGIN SYSTEM
# ═══════════════════════════════════════════════
PLUGIN_DIR=/app/plugins/strategies
PLUGIN_HOT_RELOAD=true
PLUGIN_SANDBOX_MEMORY_MB=64
PLUGIN_SANDBOX_TIMEOUT_MS=100

# ═══════════════════════════════════════════════
# OBSERVABILITY
# ═══════════════════════════════════════════════
OTEL_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=info
METRICS_ENABLED=true
TRACING_ENABLED=true
